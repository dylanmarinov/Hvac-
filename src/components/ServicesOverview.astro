---
const services = [
  {
    num: '01',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/><path d="M22 2 12 12"/></svg>`,
    title: 'AC Repair',
    desc: "Your AC shouldn't quit on a Florida summer day. We arrive fast, diagnose accurately, and fix it right — no guesswork, no callbacks.",
    color: '#3b82f6',
  },
  {
    num: '02',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2c0 6-6 7-6 12a6 6 0 0 0 12 0c0-5-6-6-6-12z"/><path d="M12 22v-4"/><path d="M9 15h6"/></svg>`,
    title: 'Heating Repair',
    desc: 'When your heat pump or furnace stops working, our certified techs respond quickly to restore warmth to your home or business.',
    color: '#f97316',
  },
  {
    num: '03',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
    title: 'Refrigeration',
    desc: 'Keeping things cold is critical. We service, repair, and maintain commercial and residential refrigeration systems so you never skip a beat.',
    color: '#06b6d4',
  },
  {
    num: '04',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Commercial HVAC',
    desc: 'Offices, restaurants, warehouses — every business deserves climate control that just works. We design, install, and service it all.',
    color: '#8b5cf6',
  },
  {
    num: '05',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 10 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>`,
    title: 'Indoor Air Quality',
    desc: "Florida's humidity demands more than cool air. We install filtration, UV purifiers, and whole-home dehumidifiers to protect what you breathe.",
    color: '#22c55e',
  },
];
---

<section id="services-overview">
  <!-- Animated background -->
  <div class="so-bg">
    <div class="so-orb so-orb1"></div>
    <div class="so-orb so-orb2"></div>
    <div class="so-grid"></div>
  </div>

  <div class="container">
    <!-- Header -->
    <div class="so-head" data-reveal>
      <div class="so-head-inner">
        <p class="so-tag">Our Services</p>
        <h2 class="so-title">Every service your home<br/>or business needs.</h2>
        <p class="so-sub">Your comfort is our craft. Apex Air delivers professional heating and cooling across Tampa Bay — backed by certified technicians who treat your property like their own.</p>
      </div>
      <a href="#contact" class="btn btn-orange">Book a Free Assessment</a>
    </div>

    <!-- Service cards -->
    <div class="so-cards" data-stagger>
      {services.map(s => (
        <a href="#contact" class="so-card" style={`--accent:${s.color}`}>
          <div class="so-num">{s.num}</div>
          <div class="so-icon" set:html={s.icon} />
          <h3 class="so-card-title">{s.title}</h3>
          <p class="so-card-desc">{s.desc}</p>
          <div class="so-arrow">
            Get a Quote
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #services-overview {
    background: var(--bg-dark);
    padding: 100px 0;
    position: relative; overflow: hidden;
  }

  /* Background */
  .so-bg { position: absolute; inset: 0; pointer-events: none; }
  .so-orb {
    position: absolute; border-radius: 50%; filter: blur(110px);
  }
  .so-orb1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(232,82,26,.18) 0%, transparent 70%);
    top: -200px; right: -100px;
    animation: soOrb 14s ease-in-out infinite;
  }
  .so-orb2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(27,61,123,.4) 0%, transparent 70%);
    bottom: -100px; left: 10%;
    animation: soOrb 10s ease-in-out infinite reverse;
    animation-delay: -5s;
  }
  @keyframes soOrb {
    0%,100% { transform: translate(0,0); }
    40%     { transform: translate(50px,-40px); }
    70%     { transform: translate(-30px,60px); }
  }
  .so-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  /* Header */
  .container { position: relative; z-index: 2; }
  .so-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 40px; margin-bottom: 64px; flex-wrap: wrap;
  }
  .so-head-inner { max-width: 680px; }
  .so-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .72rem; font-weight: 600; letter-spacing: .14em;
    text-transform: uppercase; color: var(--orange);
    margin-bottom: 16px;
  }
  .so-tag::before { content: ''; display: block; width: 22px; height: 2px; background: var(--orange); border-radius: 2px; }
  .so-title {
    font-size: clamp(2rem, 3.5vw, 3.1rem);
    font-weight: 800; line-height: 1.12; letter-spacing: -.025em;
    color: #fff; margin-bottom: 16px;
  }
  .so-sub { font-size: .95rem; color: rgba(255,255,255,.55); line-height: 1.8; }

  /* Cards */
  .so-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .so-card {
    position: relative; overflow: hidden;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.09);
    border-radius: var(--radius-lg);
    padding: 32px 24px 28px;
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; gap: 14px;
    transition: background .35s var(--ease), border-color .35s, transform .35s var(--ease), box-shadow .35s var(--ease);
  }
  .so-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--accent, var(--orange)) 0%, transparent 60%);
    opacity: 0;
    transition: opacity .4s var(--ease);
  }
  .so-card:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.2);
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(0,0,0,.4);
  }
  .so-card:hover::before { opacity: .12; }
  .so-card:hover .so-arrow { color: #fff; gap: 10px; }
  .so-card:hover .so-icon { color: var(--accent, var(--orange)); transform: scale(1.1); }

  .so-num {
    font-family: var(--font-head); font-size: 3.8rem; font-weight: 900;
    color: rgba(255,255,255,.06); line-height: 1;
    position: absolute; top: 16px; right: 20px;
    letter-spacing: -.04em;
    transition: color .35s;
  }
  .so-card:hover .so-num { color: rgba(255,255,255,.1); }

  .so-icon {
    color: rgba(255,255,255,.5);
    transition: color .3s, transform .3s var(--ease);
    position: relative; z-index: 1;
  }
  .so-card-title {
    font-size: 1rem; font-weight: 800; color: #fff;
    line-height: 1.2; position: relative; z-index: 1;
  }
  .so-card-desc {
    font-size: .81rem; color: rgba(255,255,255,.5);
    line-height: 1.7; flex: 1; position: relative; z-index: 1;
  }
  .so-arrow {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--font-head); font-size: .78rem; font-weight: 700;
    color: rgba(255,255,255,.35);
    transition: color .3s, gap .3s var(--ease);
    position: relative; z-index: 1;
  }

  /* Divider line on the right (between hero and this dark section) */
  #services-overview::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, var(--orange) 30%, #fda07a 60%, transparent 100%);
  }

  @media (max-width: 1100px) {
    .so-cards { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .so-cards { grid-template-columns: repeat(2, 1fr); }
    .so-head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .so-cards { grid-template-columns: 1fr; }
    #services-overview { padding: 72px 0; }
  }
</style>
