---
---

<section id="offer">
  <div class="container">
    <div class="offer-wrap" data-reveal>
      <div class="offer-left">
        <span class="offer-tag">Limited Time</span>
        <h2 class="offer-title">$0 Down Financing<br/>on New HVAC Systems</h2>
        <p class="offer-sub">Get approved in minutes. 18 months same-as-cash — no interest if paid in full. Available on all Carrier, Trane &amp; Lennox systems.</p>
        <div class="offer-btns">
          <a href="#contact" class="btn btn-orange">Check My Options</a>
          <a href="tel:+17275550100" class="btn btn-outline-white">Call Us Now</a>
        </div>
      </div>
      <div class="offer-right">
        <div class="offer-feature">
          <div class="of-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span>No interest for 18 months</span>
        </div>
        <div class="offer-feature">
          <div class="of-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span>Approval in 60 seconds</span>
        </div>
        <div class="offer-feature">
          <div class="of-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span>$0 down on qualified systems</span>
        </div>
        <div class="offer-feature">
          <div class="of-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span>Low monthly payment options</span>
        </div>
        <div class="offer-promo">
          <div class="op-callout">
            <span class="op-big">$500 OFF</span>
            <span class="op-sm">Any new system install<br/>Expires May 31, 2026</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #offer { background: var(--bg); border-top: 1px solid var(--border); padding: 0; }
  .offer-wrap {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, #1e4d9b 100%);
    border-radius: var(--radius-lg);
    padding: 64px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    overflow: hidden;
    position: relative;
  }
  .offer-wrap::before {
    content:'';
    position:absolute;
    top:-80px; right:-80px;
    width:320px; height:320px;
    border-radius:50%;
    background: rgba(255,255,255,.04);
  }

  .offer-tag {
    display: inline-block;
    background: var(--orange); color: #fff;
    font-size: .7rem; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; border-radius: 100px;
    padding: 5px 14px; margin-bottom: 20px;
  }
  .offer-title {
    font-size: clamp(1.8rem, 2.8vw, 2.6rem);
    font-weight: 900; line-height: 1.15; letter-spacing: -.02em;
    color: #fff; margin-bottom: 18px;
  }
  .offer-sub { font-size: .93rem; color: rgba(255,255,255,.7); line-height: 1.75; margin-bottom: 32px; }
  .offer-btns { display: flex; gap: 14px; flex-wrap: wrap; }

  .offer-right { display: flex; flex-direction: column; gap: 16px; }
  .offer-feature { display: flex; align-items: center; gap: 14px; }
  .of-icon {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    background: rgba(232,82,26,.25); color: #fda07a;
    display: flex; align-items: center; justify-content: center;
  }
  .offer-feature span { font-size: .88rem; color: rgba(255,255,255,.85); font-weight: 500; }

  .offer-promo { margin-top: 12px; }
  .op-callout {
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
    border-radius: var(--radius); padding: 20px 24px;
    display: flex; align-items: center; gap: 20px;
  }
  .op-big { font-family: var(--font-head); font-size: 2rem; font-weight: 900; color: #fda07a; line-height: 1; }
  .op-sm { font-size: .78rem; color: rgba(255,255,255,.65); line-height: 1.55; }

  @media (max-width: 960px) {
    .offer-wrap { grid-template-columns: 1fr; gap: 40px; padding: 48px 32px; }
  }
  @media (max-width: 560px) {
    .offer-wrap { padding: 36px 24px; }
    .offer-title { font-size: 1.7rem; }
  }
</style>
