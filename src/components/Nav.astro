<style>
  #nav {
    position: sticky; top:0; z-index:800;
    background: #fff;
    border-bottom: 1px solid var(--border);
    transition: box-shadow .3s;
  }
  #nav.lifted { box-shadow: 0 4px 24px rgba(0,0,0,.09); }

  .nav-inner {
    display:flex; align-items:center; gap:32px;
    padding:14px 0;
  }

  /* Logo */
  .logo { display:flex; align-items:center; gap:11px; text-decoration:none; flex-shrink:0; }
  .logo-icon {
    width:38px; height:38px; background:var(--navy); border-radius:9px;
    display:flex; align-items:center; justify-content:center; color:#fff; flex-shrink:0;
  }
  .logo-name { display:block; font-family:var(--font-head); font-weight:800; font-size:1.1rem; color:var(--navy); line-height:1.1; }
  .logo-sub  { display:block; font-size:.65rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }

  /* Links */
  .nav-links { display:flex; align-items:center; gap:4px; list-style:none; margin-left:auto; }
  .nav-links a {
    display:block; padding:8px 14px; text-decoration:none;
    font-size:.84rem; font-weight:500; color:var(--muted);
    border-radius:6px; transition:color .2s,background .2s;
  }
  .nav-links a:hover { color:var(--navy); background:var(--bg-alt); }

  /* CTAs */
  .nav-ctas { display:flex; align-items:center; gap:12px; flex-shrink:0; }
  .nav-phone {
    display:flex; align-items:center; gap:6px; text-decoration:none;
    font-family:var(--font-head); font-size:.88rem; font-weight:700;
    color:var(--navy); transition:color .2s;
  }
  .nav-phone:hover { color:var(--orange); }
  .nav-phone svg { color:var(--orange); flex-shrink:0; }
  .nav-ctas .btn { padding:11px 22px; font-size:.84rem; }

  /* Burger */
  .burger { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:none; padding:4px; }
  .burger span { display:block; width:22px; height:2px; background:var(--text); border-radius:2px; transition:.3s; }
  .burger.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
  .burger.open span:nth-child(2) { opacity:0; }
  .burger.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }

  /* Mobile nav */
  .mobile-nav {
    max-height:0; overflow:hidden; transition:max-height .4s var(--ease);
    background:#fff; border-top:1px solid var(--border);
  }
  .mobile-nav.open { max-height:500px; }
  .mobile-nav ul { list-style:none; padding:8px 0; }
  .mobile-nav a {
    display:block; padding:13px 0; font-size:1rem; font-weight:500;
    color:var(--text); text-decoration:none; border-bottom:1px solid var(--border);
    transition:color .2s;
  }
  .mobile-nav a:hover { color:var(--navy); }
  .m-ctas { display:flex; flex-direction:column; gap:10px; padding:16px 0 20px; }

  @media (max-width:960px) {
    .nav-links,.nav-ctas { display:none; }
    .burger { display:flex; margin-left:auto; }
    .mobile-nav { display:block; }
  }
</style>

<script>
  const nav=document.getElementById('nav');
  const burger=document.getElementById('burger');
  const mobileNav=document.getElementById('mobileNav');
  window.addEventListener('scroll',()=>nav?.classList.toggle('lifted',window.scrollY>10));
  burger?.addEventListener('click',()=>{
    burger.classList.toggle('open');
    mobileNav?.classList.toggle('open');
  });
  document.querySelectorAll('.mobile-nav a').forEach(a=>a.addEventListener('click',()=>{
    burger?.classList.remove('open');
    mobileNav?.classList.remove('open');
  }));
</script>
