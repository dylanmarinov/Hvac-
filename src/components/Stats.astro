---
const stats = [
  { num:2400, suffix:'+',  label:'Systems Installed',    icon:'❄️' },
  { num:15,   suffix:'+',  label:'Years in Business',    icon:'🏆' },
  { num:4900, suffix:'★',  label:'Five-Star Reviews',    icon:'⭐' },
  { num:24,   suffix:'/7', label:'Emergency Available',  icon:'⚡' },
];
---

<section id="stats">
  <div class="stats-wrap">
    <!-- Animated moving background -->
    <div class="stats-bg-orb s-orb1"></div>
    <div class="stats-bg-orb s-orb2"></div>
    <div class="stats-grid-lines"></div>

    <div class="container" style="position:relative;z-index:2">
      <div class="stats-grid" data-stagger>
        {stats.map(s => (
          <div class="stat-item">
            <span class="stat-emoji">{s.icon}</span>
            <div class="stat-row">
              <span class="stat-n" data-count={s.num}>0</span>
              <span class="stat-suf">{s.suffix}</span>
            </div>
            <p class="stat-lbl">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #stats { padding: 0; }
  .stats-wrap {
    background: linear-gradient(135deg, #0a1637 0%, var(--navy) 50%, #0f2555 100%);
    padding: 72px 0;
    position: relative; overflow: hidden;
  }

  /* Moving background orbs */
  .stats-bg-orb {
    position: absolute; border-radius: 50%;
    filter: blur(100px); pointer-events: none;
  }
  .s-orb1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(232,82,26,.2) 0%, transparent 70%);
    top: -200px; left: -100px;
    animation: statOrb 12s ease-in-out infinite;
  }
  .s-orb2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(253,160,122,.15) 0%, transparent 70%);
    bottom: -150px; right: -50px;
    animation: statOrb 16s ease-in-out infinite reverse;
    animation-delay: -6s;
  }
  @keyframes statOrb {
    0%,100% { transform: translate(0,0); }
    40%     { transform: translate(60px,-40px); }
    70%     { transform: translate(-30px,50px); }
  }

  /* Subtle grid pattern */
  .stats-grid-lines {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .stats-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    position: relative;
  }
  .stat-item {
    text-align: center; padding: 28px 32px; position: relative;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    transition: transform .3s var(--ease);
  }
  .stat-item:hover { transform: translateY(-4px); }
  .stat-item:not(:last-child)::after {
    content:''; position: absolute;
    right: 0; top: 20%; bottom: 20%;
    width: 1px; background: rgba(255,255,255,.1);
  }

  .stat-emoji { font-size: 1.8rem; margin-bottom: 6px; }
  .stat-row { display: flex; align-items: baseline; gap: 2px; }
  .stat-n {
    font-family: var(--font-head); font-weight: 900; color: #fff;
    font-size: clamp(2.4rem, 3.8vw, 3.4rem); line-height: 1;
  }
  .stat-suf {
    font-family: var(--font-head); font-weight: 800; color: #fda07a;
    font-size: clamp(1.3rem, 2.2vw, 1.8rem); line-height: 1;
  }
  .stat-lbl {
    font-size: .75rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(255,255,255,.5);
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2,1fr); }
    .stat-item:nth-child(2)::after { display: none; }
    .stat-item { padding: 22px 20px; }
  }
</style>
