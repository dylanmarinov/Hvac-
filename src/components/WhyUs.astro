---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Licensed & Insured',
    desc: "Every technician is NATE-certified and fully licensed in the state of Florida. You're covered.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Same-Day Service',
    desc: 'We dispatch certified technicians within 60 minutes for emergency calls — any time, any day.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    title: 'Upfront Pricing',
    desc: 'No hidden fees, no surprises. We give you the full quote before any work begins — guaranteed.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="20 6 9 17 4 12"/></svg>`,
    title: 'Workmanship Warranty',
    desc: 'Every installation and repair comes with a 2-year labor warranty on top of manufacturer coverage.',
  },
];
---

<section id="why-us">
  <div class="container">
    <div class="wu-grid">
      <div class="wu-img-col" data-reveal-left>
        <div class="wu-img-wrap">
          <img
            src="https://images.pexels.com/photos/5463580/pexels-photo-5463580.jpeg?auto=compress&cs=tinysrgb&w=800"
            alt="HVAC technician servicing a unit"
            class="wu-img"
          />
          <!-- Floating accent card -->
          <div class="wu-card-1">
            <div class="wc1-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <div class="wc1-title">Job Complete</div>
              <div class="wc1-sub">System running at 100%</div>
            </div>
          </div>
          <!-- Floating rating card -->
          <div class="wu-card-2">
            <div class="wc2-stars">★★★★★</div>
            <div class="wc2-text">4,900+ five-star reviews</div>
          </div>
          <!-- Decorative orange stripe -->
          <div class="wu-stripe"></div>
        </div>
      </div>

      <div class="wu-content" data-reveal-right>
        <p class="section-tag">Why Choose Us</p>
        <h2 class="section-title">The Apex Air<br/>difference.</h2>
        <p class="section-sub">We believe great HVAC service should be fast, honest, and stress-free. Here's what sets us apart from the competition.</p>

        <div class="wu-features">
          {features.map(f => (
            <div class="wu-feat">
              <div class="wu-icon" set:html={f.icon} />
              <div>
                <h4 class="wu-feat-title">{f.title}</h4>
                <p class="wu-feat-desc">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <a href="#contact" class="btn btn-orange">Schedule a Visit</a>
      </div>
    </div>
  </div>
</section>

<style>
  #why-us { background: var(--bg); border-top: 1px solid var(--border); }

  .wu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .wu-img-col { position: relative; }
  .wu-img-wrap { position: relative; display: inline-block; width: 100%; }
  .wu-img {
    width: 100%; height: 560px;
    object-fit: cover; object-position: center top;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* Orange decorative stripe */
  .wu-stripe {
    position: absolute; top: 32px; right: -16px;
    width: 6px; height: 200px; border-radius: 3px;
    background: linear-gradient(to bottom, var(--orange), transparent);
  }

  /* Floating job-complete card */
  .wu-card-1 {
    position: absolute; bottom: 32px; left: -24px;
    background: var(--navy); color: #fff;
    border-radius: 14px; padding: 16px 20px;
    display: flex; align-items: center; gap: 14px;
    box-shadow: 0 20px 56px rgba(0,0,0,.28);
    animation: floatCard 5s ease-in-out infinite;
  }
  .wc1-icon {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    background: #22c55e; display: flex; align-items: center; justify-content: center;
  }
  .wc1-title { font-family: var(--font-head); font-size: .88rem; font-weight: 700; color: #fff; }
  .wc1-sub { font-size: .72rem; color: rgba(255,255,255,.55); margin-top: 2px; }

  /* Floating rating card */
  .wu-card-2 {
    position: absolute; top: 24px; right: -24px;
    background: #fff; border-radius: 14px; padding: 14px 20px;
    box-shadow: 0 16px 48px rgba(0,0,0,.14);
    text-align: center;
    animation: floatCard 5s ease-in-out infinite;
    animation-delay: -2.5s;
  }
  .wc2-stars { color: #f59e0b; font-size: 1rem; letter-spacing: 2px; }
  .wc2-text { font-size: .72rem; font-weight: 600; color: var(--muted); margin-top: 4px; white-space: nowrap; }

  @keyframes floatCard {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }

  .wu-features { display: flex; flex-direction: column; gap: 22px; margin: 36px 0; }
  .wu-feat { display: flex; gap: 16px; align-items: flex-start; }
  .wu-icon {
    width: 46px; height: 46px; flex-shrink: 0;
    background: rgba(232,82,26,.1); border-radius: 11px;
    display: flex; align-items: center; justify-content: center;
    color: var(--orange); transition: background .25s, transform .25s;
  }
  .wu-feat:hover .wu-icon { background: var(--orange); color: #fff; transform: scale(1.08); }
  .wu-feat-title { font-size: .96rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
  .wu-feat-desc { font-size: .84rem; color: var(--muted); line-height: 1.65; }

  @media (max-width: 960px) {
    .wu-grid { grid-template-columns: 1fr; gap: 56px; }
    .wu-img { height: 380px; object-position: center center; }
    .wu-card-1 { left: 12px; bottom: 16px; }
    .wu-card-2 { right: 12px; top: 16px; }
    .wu-stripe { display: none; }
  }
</style>
